rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    match /contacts_index/{contactId} { allow read, write: if false; }
    match /contacts_detail/{contactId} { allow read, write: if false; }
    match /email_lookup/{emailId} { allow read, write: if false; }
    match /ud_key_lookup/{keyId} { allow read, write: if false; }
    match /categories/{categoryId} { allow read, write: if false; }
    match /meta/{docId} { allow read, write: if false; }
  }
}
