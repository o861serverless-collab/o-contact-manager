# ===== Core domains =====
BASE_DOMAIN=example.com
APP_DOMAIN=app.example.com
PORTAINER_DOMAIN=portainer.example.com
LOGS_DOMAIN=logs.example.com
FILES_DOMAIN=files.example.com

# ===== Caddy basic auth users (generate hash: docker run --rm caddy caddy hash-password --plaintext 'your-pass') =====
APP_BASICAUTH_USER=team
APP_BASICAUTH_HASH=$2a$14$replace_me
LOGS_BASICAUTH_USER=team
LOGS_BASICAUTH_HASH=$2a$14$replace_me
FILES_BASICAUTH_USER=team
FILES_BASICAUTH_HASH=$2a$14$replace_me

# ===== Backend runtime =====
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://app.example.com,https://localhost
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase_service_account.json
FIREBASE_DATABASE_URL=
FIREBASE_DATABASE_REGION=

# ===== Cloudflare Tunnel =====
# Create tunnel + credentials JSON first, then mount into ./secrets/cloudflared
CLOUDFLARE_TUNNEL_TOKEN=

# ===== Tailscale =====
TAILSCALE_AUTHKEY=tskey-auth-xxxx
TAILSCALE_HOSTNAME=o-contact-manager-node

# ===== Filebrowser =====
FB_USERNAME=admin
FB_PASSWORD=change-me

# ===== Optional timezone =====
TZ=UTC
