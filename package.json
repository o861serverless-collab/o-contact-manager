{
  "name": "contacts-selfhost",
  "version": "1.0.0",
  "description": "Self-hosted contact manager — Firebase Firestore + REST API",
  "main": "functions/index.js",
  "engines": { "node": ">=18" },
  "scripts": {
    "start": "node functions/index.js",
    "dev": "nodemon functions/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint functions/ scripts/ --ext .js",
    "lint:fix": "eslint functions/ scripts/ --ext .js --fix",
    "import": "node scripts/import.js",
    "migrate": "node scripts/migrate-v2.js",
    "create-key": "node scripts/create-api-key.js",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "deploy": "firebase deploy"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.1.0",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "eslintConfig": {
    "env": { "node": true, "es2022": true },
    "parserOptions": { "ecmaVersion": 2022 },
    "rules": { "no-console": "off", "no-unused-vars": "warn" }
  }
}
